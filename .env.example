# outsyde-web environment variables
# Copy to .env.local for local development.

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_TAX_ENABLED=false

# ── Resend (transactional email) ─────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Google Maps (Stripe AddressElement autocomplete) ─────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=...

# ── outsyde-backend (server-to-server only — NEVER use NEXT_PUBLIC_) ─────────
# Used by the /api/accept-invite/* BFF routes. Never exposed to the browser.
OUTSYDE_BACKEND_URL=https://outsyde-backend.onrender.com
